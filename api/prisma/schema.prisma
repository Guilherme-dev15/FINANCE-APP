generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" 
}

enum DebtType {
  CREDIT_CARD
  LOAN
  FORMAL
  INFORMAL
}

enum DebtStatus {
  ACTIVE
  NA_GAVETA
  RENEGOTIATED
  PAID
}

enum TransactionType {
  FIXED
  VARIABLE
}

enum ExpenseCategory {
  ESSENTIAL
  LIFESTYLE
  WASTE
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String    
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  debts     Debt[]
  incomes   Income[]
  expenses  Expense[]
}

model Debt {
  id                    String     @id @default(uuid())
  userId                String
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  description           String     
  originalCreditor      String?    
  debtType              DebtType   @default(LOAN)
  status                DebtStatus @default(ACTIVE)
  
  originalAmount        Decimal    @db.Decimal(12, 2) 
  currentAmount         Decimal    @db.Decimal(12, 2) 
  iofAmount             Decimal?   @db.Decimal(12, 2) 
  
  interestRate          Decimal    @db.Decimal(8, 4)  
  cetRate               Decimal?   @db.Decimal(8, 4)  
  remainingInstallments Int
  dueDate               DateTime
  
  customInstallment     Decimal?   @db.Decimal(12, 2) 
  haircutDiscount       Decimal?   @db.Decimal(5, 2)  
  informalContact       String?    
  
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
}

model Income {
  id          String          @id @default(uuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  description String
  amount      Decimal         @db.Decimal(12, 2)
  type        TransactionType @default(FIXED)
  date        DateTime
  
  createdAt   DateTime        @default(now())
}

model Expense {
  id          String          @id @default(uuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  description String
  amount      Decimal         @db.Decimal(12, 2)
  type        TransactionType @default(VARIABLE)
  category    ExpenseCategory @default(ESSENTIAL)
  date        DateTime
  
  createdAt   DateTime        @default(now())
}