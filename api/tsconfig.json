{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    
    // 🛡️ ADICIONE OU MUDE ESTAS DUAS LINHAS:
    "esModuleInterop": true, 
    "skipLibCheck": true
  },
  // 🛡️ ADICIONE O ESLINT AQUI PARA O COMPILADOR IGNORÁ-LO:
  "exclude": ["node_modules", "dist", "test", "**/*spec.ts", "eslint.config.mjs"]
}